generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  orderId     String   @id
  userId      String
  items       Json
  totalAmount Float
  status      String   @default("PENDING")
  courier     String?
  createdAt   DateTime
  updatedAt   DateTime

  @@map("orders")
}