{
  "title": "Shop — E-Commerce Platform",
  "uid": "shop-main",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Kafka Messages Produced (by topic)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(kafka_messages_produced_total[1m])",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Kafka Consumer Errors (by topic)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(kafka_consumer_errors_total[1m])",
          "legendFormat": "{{topic}} / {{groupId}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "title": "Order Processing Duration (seconds)",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(order_processing_duration_seconds_bucket[1m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Payments — Success vs Failed",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(payment_success_total[1m])",
          "legendFormat": "Success"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(payment_failure_total[1m])",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "HTTP Requests Rate (by service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{job}} {{method}} {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "title": "Stats — поточний момент",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(payment_success_total[24h])",
          "legendFormat": "Успішних оплат за 24г"
        },
        {
          "datasource": "Prometheus",
          "expr": "increase(payment_failure_total[24h])",
          "legendFormat": "Невдалих оплат за 24г"
        },
        {
          "datasource": "Prometheus",
          "expr": "increase(kafka_messages_produced_total[24h])",
          "legendFormat": "Kafka повідомлень за 24г"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      }
    }
  ],
  "schemaVersion": 38
}
